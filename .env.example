# Copy to .env.local (not committed) and fill in real values.

# DeepSeek API (OpenAI-compatible). Base URL is fixed.
DEEPSEEK_API_KEY=sk-REPLACE-ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASON=deepseek-reasoner

# Local auth: HMAC secret for the session cookie. >= 16 chars.
# Example: openssl rand -hex 32
SESSION_SECRET=change-me-to-32-hex-chars-for-prod

# Local database directory (JSON files). Default: ./data
# LOCAL_DATA_DIR=/var/lib/coc/data

# Supabase (optional, unused by default -- all storage is local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
