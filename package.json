{
  "name": "coc-engine",
  "version": "0.0.1",
  "private": true,
  "description": "Single-player BRP-compatible horror investigation engine (COC).",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "play": "tsx --env-file-if-exists=.env.local src/cli/play.ts",
    "play:dry": "tsx src/cli/play.ts --dry-run",
    "play:live": "tsx --env-file-if-exists=.env.local src/cli/play.ts --live"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.47.10",
    "bcryptjs": "^2.4.3",
    "next": "^15.1.3",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
